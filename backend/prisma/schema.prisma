// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id               Int               @id @default(autoincrement())
  nome             String
  email            String            @unique
  celular          String
  senha            String
  tipo             Int
  estabelecimentos Estabelecimento[]
  quadras          Quadra[]      
  reservas         Reserva[]
  usuarioPartidas  UsuariosPartida[]
  partidasCriadas  Partida[] @relation("CriadorPartida")
  convites         ConvitePartida[] 
}

model Estabelecimento {
  id              Int      @id @default(autoincrement())
  proprietario    Usuario  @relation(fields: [proprietario_id], references: [id])
  proprietario_id Int
  nome_local      String
  endereco        String
  quadras         Quadra[]
}

model Quadra {
  id                 Int             @id @default(autoincrement())
  descricao          String
  identificacao      String
  esporte            String?         @default("Futebol")
  valor_hora         Float?
  estabelecimento    Estabelecimento @relation(fields: [estabelecimento_id], references: [id])
  estabelecimento_id Int
  dono               Usuario         @relation(fields: [dono_id], references: [id]) 
  dono_id            Int
  disponibilidades   Disponibilidade[]
  reservas           Reserva[]             
}

enum DiaSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

model Disponibilidade {
  id          Int        @id @default(autoincrement())
  quadra      Quadra     @relation(fields: [quadra_id], references: [id])
  quadra_id   Int
  dia_semana  DiaSemana
  hora_inicio Int
  hora_fim    Int
  ativo       Boolean    @default(true)
}

model Reserva {
  id             Int       @id @default(autoincrement())
  usuario        Usuario   @relation(fields: [usuario_id], references: [id])
  usuario_id     Int
  quadra         Quadra    @relation(fields: [quadra_id], references: [id])
  quadra_id      Int
  data           DateTime
  hora_inicio    Int
  hora_fim       Int
  status         StatusReserva @default(PENDENTE)
  created_at     DateTime @default(now())
  @@unique([quadra_id, data, hora_inicio])
  partida        Partida?
}

enum StatusReserva {
  PENDENTE
  CONFIRMADA
  CANCELADA
}

model Partida {
  id                Int           @id @default(autoincrement())
  vagas             Int
  quantidade_atual  Int           @default(1)
  status            StatusPartida @default(ABERTA)
  criador           Usuario       @relation("CriadorPartida", fields: [criador_id], references: [id])
  criador_id        Int
  reserva           Reserva       @relation(fields: [reserva_id], references: [id])
  reserva_id        Int           @unique
  usuariosPartida   UsuariosPartida[]
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  convites          ConvitePartida[]
}

enum StatusPartida {
  ABERTA
  LOTADA
  ENCERRADA
  CANCELADA
}

model UsuariosPartida {
  usuario        Usuario   @relation(fields: [usuario_id], references: [id])
  usuario_id     Int
  partida        Partida   @relation(fields: [partida_id], references: [id])
  partida_id     Int
  @@id([usuario_id, partida_id])
}

model ConvitePartida {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  partida    Partida  @relation(fields: [partida_id], references: [id])
  partida_id Int
  criador    Usuario  @relation(fields: [criador_id], references: [id])
  criador_id Int
  usado      Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}