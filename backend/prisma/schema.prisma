// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id    Int     @id @default(autoincrement())
  nome  String
  email String  @unique
  senha String
  tipo Int
  quadras Quadra[]
}

model Quadra {
  id    Int     @id @default(autoincrement())
  localizacao String // pode ser discutido depois
  descricao String
  usuario Usuario @relation(fields: [idUsuario], references:[id])
  idUsuario Int
}
